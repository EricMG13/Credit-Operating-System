.next/
.next-qa*/
.next-*/
# Auto-regenerated by `next dev`/`next build` on every run ("this file should
# not be edited"); its one line churns between the dev-server and production
# build path variants depending on which command last touched it locally —
# tracking it made every parallel `next dev` session a guaranteed Fallow
# unresolved-import false-positive on the next commit. Standard Next.js
# convention (create-next-app) gitignores it; tsconfig.json's include list
# still picks it up locally without git tracking it.
caos/frontend/next-env.d.ts
out/
*.tsbuildinfo

# CAOS server build artifacts / local state
caos/server/static/
caos/server/data/
caos/data/

# Python
__pycache__/
*.pyc
.venv*/

# Secrets / local env
.env
.env.local
caos/deploy/rclone.conf

# Test artifacts
.pytest_cache/
coverage/
caos/frontend/test-results/
caos/frontend/playwright-report/
caos/frontend/private/

# Local static-analysis databases and diagnostics
/static_analysis_codeql_*/

# Superpowers brainstorming specs / scratch (local only). The Applicable Updates
# execution contract is the one deliberate tracked exception.
docs/superpowers/*
!docs/superpowers/plans/
docs/superpowers/plans/*
!docs/superpowers/plans/2026-07-13-caos-applicable-updates.md
/ds-bundle/
/.ds-sync/
/.design-sync/.cache/
/.design-sync/node_modules
/.design-sync/learnings/
caos/frontend/.ds-tailwind.css

# Playwright E2E auth state (created by global-setup)
caos/tests/frontend/e2e/.auth/

# impeccable hook cache (generated per app dir)
**/.impeccable/

# H0 release-manifest diagnostic runs are scratch evidence; only deliberate
# strict-h0 records are committed.
caos/docs/qa/release/diagnostic-*/
