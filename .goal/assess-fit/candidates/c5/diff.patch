+def _risk_flags(leverage: Optional[float]) -> list[str]:
+    """High-leverage caution: one flag iff leverage is a finite number >= 6.0.
+
+    Pure and total — non-numeric, NaN, and < 6.0 all yield []. NaN is rejected
+    because `NaN >= 6.0` is False, so it falls through to the empty list.
+    """
+    if isinstance(leverage, (int, float)) and leverage >= 6.0:
+        return [f"High leverage ({leverage:g}x) — counts against the risk budget."]
+    return []
