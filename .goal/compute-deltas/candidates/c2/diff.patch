+def _ebitda_margin(revenue, adj_ebitda) -> Optional[float]:
+    """EBITDA margin in percent, or None when it cannot be computed.
+
+    Returns a value only when both inputs are numeric AND revenue is truthy.
+    The truthy check on revenue is the divide-by-zero guard: zero revenue gives
+    no meaningful margin. A *negative* revenue is truthy, so it deliberately
+    flows through and yields a negative margin — that is the intended behaviour,
+    not a bug to clamp.
+    """
+    revenue_ok = isinstance(revenue, (int, float)) and revenue
+    ebitda_ok = isinstance(adj_ebitda, (int, float))
+    if revenue_ok and ebitda_ok:
+        return round(100 * adj_ebitda / revenue, 1)  # banker's rounding (half-even)
+    return None
+
