@@ -19,46 +19,72 @@ _BREACH_X = 7.0


+def _stress_scenario(lev: float, cov: Optional[float], shock: float) -> dict:
+    """One EBITDA-decline scenario row (pure, deterministic).
+
+    Net debt is held fixed under the shock, so stressed leverage is just
+    ``lev / (1 - shock)`` — the standard first-order downside sensitivity.
+    Coverage scales linearly with EBITDA; ``None`` if coverage is unavailable.
+    """
+    return {
+        "ebitda_shock_pct": round(shock * 100),
+        "stressed_net_leverage": round(lev / (1 - shock), 2),
+        "stressed_interest_coverage": (
+            round(cov * (1 - shock), 2) if isinstance(cov, (int, float)) else None
+        ),
+    }
+
+
+def _shock_to_breach(scenarios: list) -> Optional[int]:
+    """First scenario's ``ebitda_shock_pct`` whose stressed leverage breaches
+    ``_BREACH_X`` (inclusive), else ``None``.
+
+    Reads the already-rounded ``stressed_net_leverage`` off each row so the
+    breach test matches exactly the figure shown to the analyst.
+    """
+    for row in scenarios:
+        if row["stressed_net_leverage"] >= _BREACH_X:
+            return row["ebitda_shock_pct"]
+    return None
+
+
+def _fragility(lev: float, shock_to_breach: Optional[int]) -> str:
+    """Map current leverage + breach shock onto a fragility band (pure).
+
+    HIGH when already distressed or one mild (<=10%) shock from it; MODERATE
+    when a moderate (<=20%) shock breaches; LOW otherwise.
+    """
+    if lev >= _BREACH_X or (shock_to_breach is not None and shock_to_breach <= 10):
+        return "HIGH"
+    if shock_to_breach is not None and shock_to_breach <= 20:
+        return "MODERATE"
+    return "LOW"
+
