# Build context is caos/. Keep it lean: frontend/ + server/ source only.
# .git lives at the repo root (outside this caos/ context) so it is not baked
# today, but exclude it defensively in case the context ever widens. L-1.
**/.git
.git
**/node_modules
**/.next
**/out
**/__pycache__
**/*.pyc
**/.venv
**/.pytest_cache
**/.DS_Store
server/static
server/data
.env
.env.*
docs/
tests/
mcp/
scripts/
# The app image does not need deployment assets, but the dedicated backup
# Dockerfiles share this context and embed only their reviewed scripts.
deploy/*
!deploy/backup.sh
!deploy/backup_sync.sh
!deploy/restore_drill.sh
*.md
