# ─── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=caos
POSTGRES_PASSWORD=caospass
POSTGRES_DB=caos

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO (S3-compatible document store) ──────────────────────────────────
MINIO_ROOT_USER=caosadmin
MINIO_ROOT_PASSWORD=caossecret
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET_DOCS=caos-documents
MINIO_BUCKET_MODELS=caos-models

# ─── LLM (Anthropic Claude) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8                 # Primary agent model (latest Opus)
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001  # Lightweight/routing tasks

# ─── CORS / Frontend Origin ────────────────────────────────────────────────
# Comma-separated list of origins the API will accept. Required in prod.
CAOS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Modular OS Prompt Corpus ──────────────────────────────────────────────
# Absolute path to the Modular OS prompt corpus (CP-*_ACTIVE_PROMPT.md, etc.)
CAOS_MODULAR_OS_PATH=

# ─── Microsoft Graph API (OneDrive webhook) ────────────────────────────────
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=
MS_GRAPH_REDIRECT_URI=http://localhost:8000/api/webhooks/msgraph/auth

# ─── Vector Store ──────────────────────────────────────────────────────────
# Option A: Pinecone (cloud)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=caos-rag

# Option B: Milvus (self-hosted) - comment out Pinecone vars above
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# ─── Application ───────────────────────────────────────────────────────────
WEBHOOK_SECRET=changeme-in-prod
JWT_SECRET=changeme-in-prod
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO

# ─── MNPI / Compliance ─────────────────────────────────────────────────────
MNPI_CLASSIFICATION_ENABLED=true
AUDIT_LOG_BUCKET=caos-audit-logs
