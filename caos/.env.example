# CAOS server configuration (caos/server). All optional — the defaults run a
# fully local demo (SQLite, on-disk vault, canned chat replies).

# ─── Database ──────────────────────────────────────────────────────────────
# Default: SQLite at caos/server/data/caos.db. On Databricks point at
# Lakebase (managed Postgres):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/caos

# ─── Document vault ────────────────────────────────────────────────────────
# Default: caos/server/data/vault. On Databricks use a UC Volume:
# CAOS_STORAGE_DIR=/Volumes/main/caos/vault

# ─── LLM (Anthropic Claude) ────────────────────────────────────────────────
# Unset = chat runs in demo mode with canned replies.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# ─── Application ───────────────────────────────────────────────────────────
ENVIRONMENT=development
CAOS_DEMO_SEED=true
MAX_UPLOAD_MB=250
