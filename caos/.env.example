# CAOS server configuration (caos/server). All optional — the defaults run a
# fully local demo (SQLite, on-disk vault, canned chat replies).

# ─── Database ──────────────────────────────────────────────────────────────
# Default: SQLite at caos/server/data/caos.db. In production point at Postgres
# (the deploy/docker-compose.yml stack does this):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/caos

# ─── Document vault ────────────────────────────────────────────────────────
# Default: caos/server/data/vault. In production mount a durable volume
# (the compose stack mounts one at /vault):
# CAOS_STORAGE_DIR=/vault

# ─── LLM (Anthropic Claude) ────────────────────────────────────────────────
# Unset = chat runs in demo mode with canned replies.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# ─── LLM (OpenRouter) ──────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# OPENROUTER_MODEL_FLASH=deepseek/deepseek-v4-flash
# OPENROUTER_MODEL_GLM=z-ai/glm-5.2
# ─── Application ───────────────────────────────────────────────────────────
ENVIRONMENT=development
CAOS_DEMO_SEED=true
MAX_UPLOAD_MB=250
