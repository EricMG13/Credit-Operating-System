{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CP-1C__PeerBenchmark.schema.json",
  "title": "CP-1C PeerBenchmark Payload",
  "allOf": [{ "$ref": "CP_MODULE_PAYLOAD_BASE.schema.json" }],
  "properties": {
    "module_id": { "const": "CP-1C" },
    "module_name": { "const": "PeerBenchmark" },
    "owned_object": { "const": "peer_benchmark" },
    "schema_family": { "const": "Nested" },
    "runtime_output": {
      "type": "object",
      "properties": {
        "peer_universe": { "type": "array", "items": { "type": "object" } },
        "metric_comparison": { "type": "array", "items": { "type": "object" } },
        "outliers": { "type": "array", "items": { "type": "object" } },
        "overall_peer_view": { "type": "string" }
      }
    }
  }
}
