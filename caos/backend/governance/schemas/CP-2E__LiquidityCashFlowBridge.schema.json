{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CP-2E__LiquidityCashFlowBridge.schema.json",
  "title": "CP-2E LiquidityCashFlowBridge Payload",
  "allOf": [{ "$ref": "CP_MODULE_PAYLOAD_BASE.schema.json" }],
  "properties": {
    "module_id": { "const": "CP-2E" },
    "module_name": { "const": "LiquidityCashFlowBridge" },
    "owned_object": { "const": "liquidity_cash_flow_bridge" },
    "schema_family": { "const": "Nested" },
    "runtime_output": {
      "type": "object",
      "properties": {
        "beginning_liquidity": { "type": "array", "items": { "type": "object" } },
        "cash_uses": { "type": "array", "items": { "type": "object" } },
        "bridge": { "type": "object" },
        "liquidity_risk_level": {
          "type": "string",
          "enum": ["Adequate", "Tight", "Weak", "Insufficient Information"]
        },
        "narrative": { "type": "string" }
      }
    }
  }
}
