# CAOS self-hosted stack — copy to .env and fill in. NEVER commit .env.

# ─── App / network ─────────────────────────────────────────────────────────
# Public hostname; DNS must point at this host. Caddy provisions TLS for it.
CAOS_DOMAIN=caos.yourcompany.com

# Postgres password for the bundled db service. Use a long random value from a
# URL-SAFE alphabet (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`):
# the value is interpolated raw into DATABASE_URL, so characters like @ / # % ?
# corrupt the URL and crash-loop the app at boot (audit 2026-07-10 DEP-6).
POSTGRES_PASSWORD=change-me-long-random

# Uvicorn worker processes (E1). Leave unset for the shipped single-process
# default — this is an explicit opt-in, not automatic scale-out. Postgres
# ONLY: run.py refuses to start >1 worker against SQLite (unsafe — see its own
# docstring). Each worker opens its own DB pool (5 + 10 overflow by default,
# database.py); size against Postgres's max_connections (100 by default on
# the bundled image) — WEB_CONCURRENCY=4 uses up to 60 connections, leaving
# headroom for psql/backup/migrations. Load-test before raising in prod
# (caos/tests/stress/, loop doc L12/L13).
# WEB_CONCURRENCY=2

# Defense-in-depth for the identity-header trust (SECURITY.md §1). Caddy injects
# this on every request as X-Edge-Authorization; the app rejects any deployed
# request without it — so a forged X-Forwarded-* on a direct hit to app:8000
# (e.g. a rogue container on the internal network) is denied. The default is
# empty and production REFUSES TO START without it (same fail-closed posture as
# SESSION_SECRET below). Generate:  python -c "import secrets;print(secrets.token_urlsafe(32))"
EDGE_PROXY_SECRET=

# ─── Analyst login (app identity) ──────────────────────────────────────────
# Shared access code gating analyst self-registration. Left EMPTY on purpose —
# compose refuses to start until you set one, and production also refuses the
# public in-source defaults AND the historical "change-me-private-code"
# placeholder (a copied-unedited .env used to boot with a repo-public signup
# code; audit 2026-07-10 DEP-3). Pick a private value.
ANALYST_SIGNUP_CODE=
# HMAC key signing the analyst session cookie. The dev default is public, so
# production REFUSES TO START without a real one (login cookies forgeable otherwise).
# Generate:  python -c "import secrets;print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Upload cap (MB). Default 250.
MAX_UPLOAD_MB=250

# Optional malware scan for uploads (SECURITY.md §4). Empty = off (size cap +
# magic-byte sniff still apply). To enable: start the scanner sidecar with
#   docker compose --profile av up -d --build
# then set CLAMAV_HOST=clamav and `docker compose up -d` the app. A set-but-
# unreachable scanner fails CLOSED — uploads return 503 — so set it only once the
# clamav service is healthy (`docker compose ps`).
CLAMAV_HOST=

# Structure-preserving document extraction. The markitdown CLI is baked into the
# image (Dockerfile); set this to use it for PDF tables / multi-column credit
# agreements and EDGAR .htm exhibits. Empty = built-in pypdf/openpyxl fallback
# (fine for clean text-layer PDFs; mangles dense tables). No effect on scanned
# image PDFs — neither path OCRs, those still produce zero chunks.
CAOS_MARKITDOWN_CMD=markitdown

# ─── Applicable-updates rollout gates ─────────────────────────────────────
# Keep every gate false on first deploy. Enable only in the documented order
# after the preceding stage has passed its observation window and rollback
# rehearsal (docs/APPLICABLE_UPDATES_PHASE7_RELEASE.md).
CAOS_LINEAGE_V2_ENABLED=false
CAOS_MARKET_XLSX_V2_ENABLED=false
CAOS_MODEL_ENGINE_V2_ENABLED=false
CAOS_CP_4D_ENABLED=false
CAOS_CP_2G_ENABLED=false

# ─── Backups (P7-1) ────────────────────────────────────────────────────────
# The `backup` service writes daily pg_dump + vault tarballs to the `backups`
# volume with rotation (defaults: daily, keep 7). Copy /backups OFF the host
# (rsync / object storage) for real host-loss protection — set BACKUP_SYNC_CMD
# to run that copy automatically after each backup cycle.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
# Off-host sync hook, run inside the backup container after each cycle (empty = off).
# The postgres:18-alpine image has no rsync/aws CLI baked in — either use a
# mounted-volume copy target or bake the tool into a derived image.
# BACKUP_SYNC_CMD=cp -r /backups/. /mnt/offhost/caos-backups/

# ─── LLM (Anthropic Claude) ────────────────────────────────────────────────
# Empty = chat/synthesis fall back to deterministic demo replies.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─── SEC EDGAR covenant lane ───────────────────────────────────────────────
# SEC fair-access requires a descriptive contact string; the /api/edgar routes
# 503 until this is set. No key, no cost.
EDGAR_USER_AGENT=Your Firm Research research@yourfirm.example

# ─── Auth (oauth2-proxy → Google Workspace OIDC) ───────────────────────────
# Restrict sign-in to your workspace domain (comma-separate for several).
CAOS_EMAIL_DOMAIN=yourcompany.com
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (Web application). Authorized redirect URI: https://<CAOS_DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
# Generate with:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=
