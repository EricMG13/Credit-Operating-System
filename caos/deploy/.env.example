# CAOS self-hosted stack — copy to .env and fill in. NEVER commit .env.

# ─── App / network ─────────────────────────────────────────────────────────
# Public hostname; DNS must point at this host. Caddy provisions TLS for it.
CAOS_DOMAIN=caos.yourcompany.com

# Postgres password for the bundled db service. Use a long random value from a
# URL-SAFE alphabet (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`):
# the value is interpolated raw into DATABASE_URL, so characters like @ / # % ?
# corrupt the URL and crash-loop the app at boot (audit 2026-07-10 DEP-6).
POSTGRES_PASSWORD=change-me-long-random

# Uvicorn worker processes (E1). Supported values: 1 or 2; run.py refuses more.
# Each process opens a DB pool of 5 + 10 overflow, so WEB_CONCURRENCY=2 has a
# calculated ceiling of 30 app connections, leaving 70 of Postgres's default
# 100 for migrations, backup, probes, and operator access. Postgres only above 1.
# WEB_CONCURRENCY=2

# One buffered upload/parser lane per process. Keep at 1 with 250 MiB uploads.
CAOS_UPLOAD_CONCURRENCY=1

# Defense-in-depth for the identity-header trust (SECURITY.md §1). Caddy injects
# this on every request as X-Edge-Authorization; the app rejects any deployed
# request without it — so a forged X-Forwarded-* on a direct hit to app:8000
# (e.g. a rogue container on the internal network) is denied. The default is
# empty and production REFUSES TO START without it (same fail-closed posture as
# SESSION_SECRET below). Production requires at least 32 UTF-8 bytes. Generate:
# python -c "import secrets;print(secrets.token_urlsafe(32))"
EDGE_PROXY_SECRET=

# ─── Analyst login (app identity) ──────────────────────────────────────────
# Shared access code gating analyst self-registration. Left EMPTY on purpose —
# compose refuses to start until you set one, and production also refuses the
# public in-source defaults AND the historical "change-me-private-code"
# placeholder (a copied-unedited .env used to boot with a repo-public signup
# code; audit 2026-07-10 DEP-3). Use at least 16 UTF-8 bytes of randomly
# generated material.
ANALYST_SIGNUP_CODE=
# HMAC key signing the analyst session cookie. The dev default is public, so
# production REFUSES TO START without a real one (login cookies forgeable otherwise).
# Production requires at least 32 UTF-8 bytes. Generate:
# python -c "import secrets;print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Upload cap (MB). Default 250.
MAX_UPLOAD_MB=250

# ClamAV is mandatory in the production Compose stack and wired internally as
# clamav:3310. No host setting is required here; app startup waits for health.

# Structure-preserving document extraction. The markitdown CLI is baked into the
# image (Dockerfile); set this to use it for PDF tables / multi-column credit
# agreements and EDGAR .htm exhibits. Empty = built-in pypdf/openpyxl fallback
# (fine for clean text-layer PDFs; mangles dense tables). No effect on scanned
# image PDFs — neither path OCRs, those still produce zero chunks.
CAOS_MARKITDOWN_CMD=markitdown

# ─── Applicable-updates rollout gates ─────────────────────────────────────
# Keep every gate false on first deploy. Enable only in the documented order
# after the preceding stage has passed its observation window and rollback
# rehearsal (docs/APPLICABLE_UPDATES_PHASE7_RELEASE.md).
CAOS_LINEAGE_V2_ENABLED=false
CAOS_MARKET_XLSX_V2_ENABLED=false
CAOS_MODEL_ENGINE_V2_ENABLED=false
CAOS_CP_4D_ENABLED=false
CAOS_CP_2G_ENABLED=false

# ─── Backups (P7-1) ────────────────────────────────────────────────────────
# The `backup` service writes daily pg_dump + vault tarballs to the `backups`
# volume with rotation (defaults: daily, keep 7). The separate `backup-sync`
# service gets that volume read-only, uploads through rclone, and periodically
# restores a newly downloaded remote copy into scratch DB/vault targets.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
# Run a scratch DB+vault restore after every N successful cycles (7 = weekly at
# the daily default). A drill failure marks the backup service unhealthy.
BACKUP_RESTORE_DRILL_EVERY=7
BACKUP_SYNC_INTERVAL_SECONDS=86400
BACKUP_REMOTE_RESTORE_DRILL_EVERY=7
# REQUIRED: provider-neutral rclone target and secret config. Copy
# rclone.conf.example outside source control, fill its backend credentials, and
# set the path below. Compose refuses an unprotected launch.
BACKUP_REMOTE=offhost:caos/production
BACKUP_RCLONE_CONFIG_FILE=./rclone.conf

# ─── LLM providers + explicit document-egress policy ───────────────────────
# Keys alone do not enable source-document egress. Keep the policy false for a
# fully local/fixture posture; set it true only after the data owner approves the
# selected providers and models for confidential credit material.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=
CAOS_DOCUMENT_EGRESS_ENABLED=false
MODEL_TIER_CHEAP=deepseek/deepseek-v4-flash
MODEL_TIER_FAST=deepseek/deepseek-v4-flash
MODEL_TIER_STRONG=deepseek/deepseek-v4-pro
MODEL_TIER_TOP=claude-opus-4-8
CAOS_LLM_TIMEOUT_S=120
RUN_TOKEN_BUDGET=120000
SYNTH_CONCURRENCY=4

# Optional live reasoning lanes. Each remains independently fail-closed/off.
RERANK_ENABLED=false
RERANK_MODEL_TIER=cheap
RERANK_WINDOW=20
COUNCIL_ENABLED=false
COUNCIL_SEATS=4
COUNCIL_PEER_ROUND=false
COUNCIL_CROSS_MODEL=false
COUNCIL_REVIEWER_MODEL_ANTHROPIC=claude-sonnet-4-6
COUNCIL_REVIEWER_MODEL_GEMINI=gemini-2.5-flash
DEBATE_ENABLED=false
ADVISOR_ENABLED=false
SYNTH_EXECUTOR_MODEL=claude-sonnet-4-6
ADVISOR_MODEL=claude-opus-4-8

# ─── SEC EDGAR covenant lane ───────────────────────────────────────────────
# SEC fair-access requires a descriptive contact string; the /api/edgar routes
# 503 until this is set. No key, no cost.
EDGAR_USER_AGENT=Your Firm Research research@yourfirm.example
# Total app processes across every replica. The per-process interval is
# 0.15 × this value, so aggregate EDGAR traffic stays at or below 6.67 req/s.
CAOS_SEC_RATE_PARTITIONS=1

# ─── Auth (oauth2-proxy → Google Workspace OIDC) ───────────────────────────
# Restrict sign-in to your workspace domain (comma-separate for several).
CAOS_EMAIL_DOMAIN=yourcompany.com
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (Web application). Authorized redirect URI: https://<CAOS_DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
# Generate with:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=
