# CAOS self-hosted stack — copy to .env and fill in. NEVER commit .env.

# ─── App / network ─────────────────────────────────────────────────────────
# Public hostname; DNS must point at this host. Caddy provisions TLS for it.
CAOS_DOMAIN=caos.yourcompany.com

# Postgres password for the bundled db service (use a long random value).
POSTGRES_PASSWORD=change-me-long-random

# Upload cap (MB). Default 250.
MAX_UPLOAD_MB=250

# ─── Backups (P7-1) ────────────────────────────────────────────────────────
# The `backup` service writes daily pg_dump + vault tarballs to the `backups`
# volume with rotation (defaults: daily, keep 7). Copy /backups OFF the host
# (rsync / object storage) for real host-loss protection.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7

# ─── LLM (Anthropic Claude) ────────────────────────────────────────────────
# Empty = chat/synthesis fall back to deterministic demo replies.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─── SEC EDGAR covenant lane ───────────────────────────────────────────────
# SEC fair-access requires a descriptive contact string; the /api/edgar routes
# 503 until this is set. No key, no cost.
EDGAR_USER_AGENT=Your Firm Research research@yourfirm.example

# ─── Auth (oauth2-proxy → Google Workspace OIDC) ───────────────────────────
# Restrict sign-in to your workspace domain (comma-separate for several).
CAOS_EMAIL_DOMAIN=yourcompany.com
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (Web application). Authorized redirect URI: https://<CAOS_DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
# Generate with:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=
