# TLS edge. Caddy auto-provisions a Let's Encrypt cert for a public domain that
# resolves to this host (ports 80/443 open). For an internal-only host with no
# public DNS, replace the site line with `https://{$CAOS_DOMAIN}` and add
# `tls internal` inside the block (Caddy issues a local CA cert).

{$CAOS_DOMAIN} {
	encode gzip

	# SECURITY.md §1: the header-trust model is safe only if the edge is the
	# sole setter of identity. Strip any client-supplied identity headers so a
	# caller cannot spoof them; only oauth2-proxy may set them downstream.
	request_header -X-Forwarded-User
	request_header -X-Forwarded-Email
	request_header -X-Forwarded-Preferred-Username
	request_header -X-Forwarded-Groups
	request_header -X-Forwarded-Access-Token
	# Also strip the edge credential so a client can't supply it (we set it below).
	request_header -X-Edge-Authorization

	# Defense-in-depth (W1): inject the shared edge secret so the app can prove a
	# request actually transited the edge, not a direct hit to app:8000 with forged
	# headers. oauth2-proxy forwards this header to the upstream app. Empty when
	# EDGE_PROXY_SECRET is unset → the app leaves enforcement off. Verify on first
	# deploy that the app sees X-Edge-Authorization (oauth2-proxy passthrough).
	reverse_proxy oauth2-proxy:4180 {
		header_up X-Edge-Authorization {$EDGE_PROXY_SECRET}
	}
}
