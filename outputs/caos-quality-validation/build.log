ion': 'bottom', 'textStyle': {'fontSize': 11}, 'fill': {'type': 'solid', 'color': 'background1', 'pattern': {'type': 'zigZag', 'color': 'accent2'}}, 'stroke': {'fill': 'accent2', 'style': 'solid', 'width': 1}}"].join("\n"),summary:"Legend on/off + position + style"}]}}},{kind:"api",name:"chart barOptions",summary:"Bar/column chart layout options.",languages:{javascript:{examples:[{summary:"Column chart spacing + overlap",code:["chart.barOptions.direction = 'column';","chart.barOptions.grouping = 'clustered';","chart.barOptions.gapWidth = 100;","chart.barOptions.overlap = -20;","chart.barOptions.direction = 'column';","chart.barOptions.grouping = 'stacked';","chart.barOptions.gapWidth = 120;"].join("\n")}]},python:{functionName:"chart.bar_options",examples:[{code:["chart.bar_options = {'direction': 'column', 'grouping': 'clustered', 'gapWidth': 100, 'overlap': -20}","chart.bar_options = {'direction': 'column', 'grouping': 'stacked', 'gapWidth': 120}"].join("\n"),summary:"Column chart spacing + overlap"}]}}},{kind:"api",name:"chart axes",summary:"Axis config (type, position, titles, ticks, gridlines, formats, and styling).",notes:["Use chart.xAxis and chart.yAxis to configure the primary axes.","Axis config setters merge; apply small patches without resetting other axis fields."],languages:{javascript:{examples:[{summary:"Axis type + presence",code:["chart.xAxis = { axisType: 'textAxis' };","chart.xAxis = { axisType: 'dateAxis' };","chart.xAxis = { deleted: true, title: 'Years' };","chart.yAxis = { deleted: true, title: 'Revenue' };"].join("\n")},{summary:"Axis titles + text styles (avoid redundant defaults)",code:["chart.xAxis = { title: { text: 'Category', textStyle: { fontSize: 14, bold: true } } };","chart.yAxis = { title: { text: 'Value', textStyle: { fontSize: 12, italic: true, fill: 'accent1' } } };"].join("\n")},{summary:"Axis ordering + crossing",code:["chart.xAxis = { position: 'bottom', orientation: 'maxMin' };","chart.yAxis = { position: 'left', crossBetween: 'between' };","chart.yAxis = { crosses: 'autoZero' };","chart.yAxis = { crossesAt: 2 };","chart.yAxis = { crosses: 'max' };"].join("\n")},{summary:"Tick labels",code:["chart.xAxis = { tickLabelPosition: 'nextTo' };","chart.xAxis = { tickLabelPosition: 'high' };","chart.xAxis = { tickLabelPosition: 'low' };","chart.xAxis = { tickLabelPosition: 'none', tickLabelInterval: 2, tickLabelDistanceFromAxis: 10 };"].join("\n")},{summary:"Tick marks + units",code:["chart.xAxis = { majorUnit: 5, minorUnit: 1 };","chart.xAxis = { majorTickMark: 'outside', minorTickMark: 'inside' };","chart.yAxis = { majorTickMark: 'cross', minorTickMark: 'none' };"].join("\n")},{summary:"Gridlines + axis lines",code:["chart.yAxis = { majorGridlines: { fill: 'background2', style: 'dashed', width: 1 }, minorGridlines: { fill: 'background2', style: 'dotted', width: 0.5 } };","chart.xAxis = { majorGridlines: { fill: 'background2', style: 'solid', width: 1 }, minorGridlines: { fill: 'background2', style: 'dotted', width: 0.5 } };","chart.xAxis = { line: { fill: 'background2', style: 'solid', width: 1 } };","chart.yAxis = { line: { fill: 'background2', style: 'solid', width: 1 } };","","// Hide gridlines:","chart.yAxis = { majorGridlines: null, minorGridlines: null };","chart.xAxis = { majorGridlines: null, minorGridlines: null };"].join("\n")},{summary:"Number formats",code:["chart.xAxis = { numberFormatCode: '0', numberFormatSourceLinked: true };"].join("\n")},{summary:"Axis text style",code:["chart.xAxis = { textStyle: { fontSize: 10 } };","chart.yAxis = { textStyle: { fontSize: 1, fill: 'background1' } };"].join("\n")}]},python:{functionName:"chart.x_axis",examples:[{code:["chart.x_axis = {'axisType': 'textAxis'}","chart.x_axis = {'axisType': 'dateAxis'}","chart.x_axis = {'deleted': True, 'title': 'Years'}","chart.y_axis = {'deleted': True, 'title': 'Revenue'}"].join("\n"),summary:"Axis type + presence"},{code:["chart.x_axis = {'title': {'text': 'Category', 'textStyle': {'fontSize': 14, 'bold': True}}}","chart.y_axis = {'title': {'text': 'Value', 'textStyle': {'fontSize': 12, 'italic': True, 'fill': 'accent1'}}}"].join("\n"),summary:"Axis titles + text styles (avoid redundant defaults)"},{code:["chart.x_axis = {'position': 'bottom', 'orientation': 'maxMin'}","chart.y_axis = {'position': 'left', 'crossBetween': 'between'}","chart.y_axis = {'crosses': 'autoZero'}","chart.y_axis = {'crossesAt': 2}","chart.y_axis = {'crosses': 'max'}"].join("\n"),summary:"Axis ordering + crossing"},{code:["chart.x_axis = {'tickLabelPosition': 'nextTo'}","chart.x_axis = {'tickLabelPosition': 'high'}","chart.x_axis = {'tickLabelPosition': 'low'}","chart.x_axis = {'tickLabelPosition': 'none', 'tickLabelInterval': 2, 'tickLabelDistanceFromAxis': 10}"].join("\n"),summary:"Tick labels"},{code:["chart.x_axis = {'majorUnit': 5, 'minorUnit': 1}","chart.x_axis = {'majorTickMark': 'outside', 'minorTickMark': 'inside'}","chart.y_axis = {'majorTickMark': 'cross', 'minorTickMark': 'none'}"].join("\n"),summary:"Tick marks + units"},{code:["chart.y_axis = {'majorGridlines': {'fill': 'background2', 'style': 'dashed', 'width': 1}, 'minorGridlines': {'fill': 'background2', 'style': 'dotted', 'width': 0.5}}","chart.x_axis = {'majorGridlines': {'fill': 'background2', 'style': 'solid', 'width': 1}, 'minorGridlines': {'fill': 'background2', 'style': 'dotted', 'width': 0.5}}","chart.x_axis = {'line': {'fill': 'background2', 'style': 'solid', 'width': 1}}","chart.y_axis = {'line': {'fill': 'background2', 'style': 'solid', 'width': 1}}","chart.y_axis = {'majorGridlines': None, 'minorGridlines': None}","chart.x_axis = {'majorGridlines': None, 'minorGridlines': None}"].join("\n"),summary:"Gridlines + axis lines"},{code:["chart.x_axis = {'numberFormatCode': '0', 'numberFormatSourceLinked': True}"].join("\n"),summary:"Number formats"},{code:["chart.x_axis = {'textStyle': {'fontSize': 10}}","chart.y_axis = {'textStyle': {'fontSize': 1, 'fill': 'background1'}}"].join("\n"),summary:"Axis text style"}]}}},{kind:"api",name:"categoryAxis",summary:"Alias for the chart category axis. In Granola, this maps to chart.xAxis.",notes:["Prefer chart.xAxis = { ... } for config-style edits.","Also available as chart.axes.categoryAxis."],languages:{javascript:{examples:[{summary:"Show category axis tick labels",code:["chart.xAxis = { deleted: false, tickLabelPosition: 'nextToAxis' };"].join("\n")}]},python:{functionName:"chart.x_axis",examples:[{code:["chart.x_axis = {'deleted': False, 'tickLabelPosition': 'nextToAxis'}"].join("\n"),summary:"Show category axis tick labels"}]}}},{kind:"api",name:"valueAxis",summary:"Alias for the chart value axis. In Granola, this maps to chart.yAxis.",notes:["Prefer chart.yAxis = { ... } for config-style edits.","Also available as chart.axes.valueAxis."],languages:{javascript:{examples:[{summary:"Format value axis gridlines",code:["chart.yAxis = { majorGridlines: { fill: 'background2', style: 'dashed', width: 1 } };"].join("\n")}]},python:{functionName:"chart.y_axis",examples:[{code:["chart.y_axis = {'majorGridlines': {'fill': 'background2', 'style': 'dashed', 'width': 1}}"].join("\n"),summary:"Format value axis gridlines"}]}}},{kind:"api",name:"chart.xAxis",summary:"Primary x-axis (category axis) config setter.",notes:["Assign a config object: chart.xAxis = { ... }. Omitted fields keep current values.","Compat name: categoryAxis."],languages:{javascript:{examples:[{summary:"Make x-axis labels visible",code:["chart.xAxis = { visible: true, tickLabelPosition: 'nextToAxis' };"].join("\n")}]},python:{functionName:"chart.x_axis",examples:[{code:["chart.x_axis = {'visible': True, 'tickLabelPosition': 'nextToAxis'}"].join("\n"),summary:"Make x-axis labels visible"}]}}},{kind:"api",name:"chart.yAxis",summary:"Primary y-axis (value axis) config setter.",notes:["Assign a config object: chart.yAxis = { ... }. Omitted fields keep current values.","Compat name: valueAxis."],languages:{javascript:{examples:[{summary:"Set y-axis title",code:["chart.yAxis = { title: { text: 'Revenue' } };"].join("\n")}]},python:{functionName:"chart.y_axis",examples:[{code:["chart.y_axis = {'title': {'text': 'Revenue'}}"].join("\n"),summary:"Set y-axis title"}]}}},{kind:"api",name:"chart dataLabels",summary:"Chart-level data labels (including callouts and pattern fills).",notes:["Use chart.dataLabels for defaults applied to all series/points.","For per-point customization, use series.dataLabelOverrides (see separate help entry)."],languages:{javascript:{examples:[{summary:"Positions + minimal style",code:["chart.dataLabels = { showValue: false, position: undefined };","chart.dataLabels = { showValue: true, position: 'center', textStyle: { fontSize: 9 } };","chart.dataLabels = { showValue: true, position: 'inEnd' };","chart.dataLabels = { showValue: true, position: 'inBase' };","chart.dataLabels = { showValue: true, position: 'outEnd', textStyle: { bold: true, fontSize: 10 } };"].join("\n")},{summary:"Data callout styling (fill + stroke)",code:["chart.dataLabels = { showValue: true, position: 'dataCallout', fill: { type: 'solid', color: 'background1', pattern: { type: 'percent20', color: 'accent1' } }, stroke: { fill: 'accent1', style: 'solid', width: 1 } };"].join("\n")}]},python:{functionName:"chart.data_labels",examples:[{code:["chart.data_labels = {'showValue': False, 'position': None}","chart.data_labels = {'showValue': True, 'position': 'center', 'textStyle': {'fontSize': 9}}","chart.data_labels = {'showValue': True, 'position': 'inEnd'}","chart.data_labels = {'showValue': True, 'position': 'inBase'}","chart.data_labels = {'showValue': True, 'position': 'outEnd', 'textStyle': {'bold': True, 'fontSize': 10}}"].join("\n"),summary:"Positions + minimal style"},{code:["chart.data_labels = {'showValue': True, 'position': 'dataCallout', 'fill': {'type': 'solid', 'color': 'background1', 'pattern': {'type': 'percent20', 'color': 'accent1'}}, 'stroke': {'fill': 'accent1', 'style': 'solid', 'width': 1}}"].join("\n"),summary:"Data callout styling (fill + stroke)"}]}}},{kind:"api",name:"chart dataTable",summary:"Chart data table visibility and styling.",languages:{javascript:{examples:[{summary:"Data table with optional legend keys",code:["chart.dataTable = { visible: true, showLegendKey: true, textStyle: { fontSize: 10 }, fill: { type: 'solid', color: 'background1', pattern: { type: 'smallGrid', color: 'accent3' } } };","chart.dataTable = { visible: true, showLegendKey: false };"].join("\n")}]},python:{functionName:"chart.data_table",examples:[{code:["chart.data_table = {'visible': True, 'showLegendKey': True, 'textStyle': {'fontSize': 10}, 'fill': {'type': 'solid', 'color': 'background1', 'pattern': {'type': 'smallGrid', 'color': 'accent3'}}}","chart.data_table = {'visible': True, 'showLegendKey': False}"].join("\n"),summary:"Data table with optional legend keys"}]}}},{kind:"api",name:"chart series",summary:"Series data, styling, number formats, error bars, trendlines, and label overrides.",languages:{javascript:{examples:[{summary:"Series styling via worksheet.charts.add config",code:["const chart = worksheet.charts.add('bar', { categories: ['Q1','Q2'], series: [{ name: '2025', values: [18, 14], line: { fill: '#7c3aed', style: 'solid', width: 2 }, fill: { type: 'solid', color: '#ede9fe', pattern: { type: 'smallCheck', color: '#8b5cf6' } } }, { name: '2026', values: [21, 17], line: { fill: '#d97706', style: 'solid', width: 2 }, fill: { type: 'solid', color: '#fef3c7', pattern: { type: 'dottedDiamond', color: '#f59e0b' } } }] });"].join("\n")},{summary:"Scatter series with xValues (config)",code:["const chart = worksheet.charts.add('scatter', { series: [{ name: 'S1', xValues: [1, 2, 3, 4], values: [2, 4, 3, 5] }] });"].join("\n")},{summary:"Create a series and set categories/values (one-liners)",code:["chart.categories = ['A', 'B', 'C'];","const series = chart.series.add('S1'); series.categories = chart.categories; series.values = [1, 2, 3];"].join("\n")},{summary:"Series value number format code",code:["chart.series.items[0]!.valuesFormatCode = '$0.00';"].join("\n")},{summary:"Error bars",code:["const series = chart.series.items[0]!;","series.errorBars = { type: 'standardError', line: { fill: 'accent1', style: 'solid', width: 1 } };","series.errorBars = { type: 'percentage', value: 5 };","series.errorBars = { type: 'standardDeviation' };"].join("\n")},{summary:"Trendlines",code:["const series = chart.series.items[0]!;","series.trendlines.add('linear', { forecastForward: 2, forecastBackward: 1, intercept: 0, displayEquation: true, displayRSquared: true, stroke: { fill: 'accent1', style: 'dashed', width: 1 } });","series.trendlines.add('polynomial', { polynomialOrder: 3 });","series.trendlines.add('movingAverage', { movingAveragePeriod: 5 });","series.trendlines.add('exponential');","series.trendlines.clear();"].join("\n")},{summary:"Trendline styling (label fill + line alias)",code:["const trend = series.trendlines.add('linear', { line: { fill: 'accent5', style: 'dashed', width: 1 }, label: { fill: { type: 'solid', color: 'background1', pattern: { type: 'smallCheck', color: 'accent6' } } } });"].join("\n")},{summary:"Per-point data label overrides",code:["const series = chart.series.items[1]!;","const label0 = series.dataLabelOverrides.add(0);","label0.showValue = true;","label0.position = 'inEnd';","label0.textStyle.bold = true;","label0.textStyle.fontSize = 10;"].join("\n")},{summary:"Series styling after creation (one-liners)",code:["chart.series.items[0]!.line = { fill: '#3b82f6', style: 'solid', width: 2 };","chart.series.items[0]!.fill = { type: 'solid', color: '#60a5fa' };"].join("\n")},{summary:"Outline-only bars (no fill + visible stroke)",code:["const series = chart.series.items[0]!;","series.fill = { type: 'none' };","series.stroke = { color: 'accent5', style: 'solid', weight: 1.5 };","","// Equivalent format-style surface (useful for agent code):","series.format.fill.clear();","series.format.line = { color: 'accent5', style: 'solid', weight: 1.5 };"].join("\n")}]},python:{functionName:"chart.series",examples:[{code:["chart = worksheet.charts.add('bar', {'categories': ['Q1', 'Q2'], 'series': [{'name': '2025', 'values': [18, 14], 'line': {'fill': '#7c3aed', 'style': 'solid', 'width': 2}, 'fill': {'type': 'solid', 'color': '#ede9fe', 'pattern': {'type': 'smallCheck', 'color': '#8b5cf6'}}}, {'name': '2026', 'values': [21, 17], 'line': {'fill': '#d97706', 'style': 'solid', 'width': 2}, 'fill': {'type': 'solid', 'color': '#fef3c7', 'pattern': {'type': 'dottedDiamond', 'color': '#f59e0b'}}}]})"].join("\n"),summary:"Series styling via worksheet.charts.add config"},{code:["chart = worksheet.charts.add('scatter', {'series': [{'name': 'S1', 'xValues': [1, 2, 3, 4], 'values': [2, 4, 3, 5]}]})"].join("\n"),summary:"Scatter series with xValues (config)"},{code:["chart.categories = ['A', 'B', 'C']","series = chart.series.add('S1')","series.categories = chart.categories","series.values = [1, 2, 3]"].join("\n"),summary:"Create a series and set categories/values (one-liners)"},{code:["chart.series.items[0].values_format_code = '$0.00'"].join("\n"),summary:"Series value number format code"},{code:["series = chart.series.items[0]","series.error_bars = {'type': 'standardError', 'line': {'fill': 'accent1', 'style': 'solid', 'width': 1}}","series.error_bars = {'type': 'percentage', 'value': 5}","series.error_bars = {'type': 'standardDeviation'}"].join("\n"),summary:"Error bars"},{code:["series = chart.series.items[0]","series.trendlines.add('linear', {'forecastForward': 2, 'forecastBackward': 1, 'intercept': 0, 'displayEquation': True, 'displayRSquared': True, 'stroke': {'fill': 'accent1', 'style': 'dashed', 'width': 1}})","series.trendlines.add('polynomial', {'polynomialOrder': 3})","series.trendlines.add('movingAverage', {'movingAveragePeriod': 5})","series.trendlines.add('exponential')","series.trendlines.clear()"].join("\n"),summary:"Trendlines"},{code:["trend = series.trendlines.add('linear', {'line': {'fill': 'accent5', 'style': 'dashed', 'width': 1}, 'label': {'fill': {'type': 'solid', 'color': 'background1', 'pattern': {'type': 'smallCheck', 'color': 'accent6'}}}})"].join("\n"),summary:"Trendline styling (label fill + line alias)"},{code:["series = chart.series.items[1]","label0 = series.data_label_overrides.add(0)","label0.show_value = True","label0.position = 'inEnd'","label0.text_style.bold = True","label0.text_style.font_size = 10"].join("\n"),summary:"Per-point data label overrides"},{code:["chart.series.items[0].line = {'fill': '#3b82f6', 'style': 'solid', 'width': 2}","chart.series.items[0].fill = {'type': 'solid', 'color': '#60a5fa'}"].join("\n"),summary:"Series styling after creation (one-liners)"},{code:["series = chart.series.items[0]","series.fill = {'type': 'none'}","series.stroke = {'color': 'accent5', 'style': 'solid', 'weight': 1.5}","series.format.fill.clear()","series.format.line = {'color': 'accent5', 'style': 'solid', 'weight': 1.5}"].join("\n"),summary:"Outline-only bars (no fill + visible stroke)"}]}}}];var QJn=[{kind:"api",name:"sparklines",summary:"Sparkline groups for compact trend visuals.",notes:["Use worksheet.sparklines.add({ type, targetRange, sourceData }).","Use worksheet.sparklines.getAll() to list groups.","Use worksheet.sparklines.deleteAll() to remove all groups (safe no-op when empty).","worksheet.sparklines is an alias for worksheet.sparklineGroups."]},{kind:"api",name:"worksheet.sparklines.add",summary:"Create a sparkline group for a target range.",languages:{javascript:{examples:[{code:["sheet.getRange('A1:A6').values = [[1],[2],[3],[2],[4],[6]];","const group = sheet.sparklines.add({","  type: 'line',","  sourceData: sheet.getRange('A1:A6'),","  targetRange: sheet.getRange('B1:B6'),","});","group.displayXAxis = true;"].join("\n"),summary:"Add a line sparkline group"}]},python:{functionName:"worksheet.sparklines.add",examples:[{code:["sheet.get_range('A1:A6').values = [[1], [2], [3], [2], [4], [6]]","group = sheet.sparklines.add({","  'type': 'line',","  '