r({","  sheetName: 'Summary',","  range: 'A1:D12',","  format: 'png',","});"].join("\n"),summary:"Render a range preview"}]},python:{functionName:"workbook.render",examples:[{code:["png = workbook.render({","  'sheetName': 'Summary',","  'range': 'A1:D12',","  'format': 'png',","})"].join("\n"),summary:"Render a range preview"}]}}},{kind:"api",name:"workbook.help",summary:"Return NDJSON help about workbook APIs via query and regex search",notes:["Tip: query matches entry names, not example bodies. ","To find an API by keyword, use query='*' to grep across the help index and search=<regex>","Search uses regex matching; for multiple terms use pipes (example: freeze|pane|freeze_panes).","Use `include` param to control payload size.","Formula metadata is exposed under fx.<NAME> entries (ex: fx.LET).","Enums are listed under enum.<Name> (ex: enum.ShapeGeometry)."],examples:[{code:["workbook.help(","  'enum.ShapeGeometry',","  { include: ['index','notes'] },",")"].join("\n"),summary:"Get help for a specific enums"},{code:["workbook.help(","  'enum.*',","  { search: 'ShapeGeometry|LineStyle', include: ['index'] },",")"].join("\n"),summary:"Get help for multiple enums"},{code:["workbook.help({query: '*', search: 'trendline|trendlines', include: ['index','examples']})."].join("\n"),summary:"Get help on specific features by regex search"},{query:"ranges",include:["index","examples"],search:null,maxChars:1200,summary:"Range addressing and value/formula basics"},{query:"styles",include:["index","examples"],search:null,maxChars:1200,summary:"Formatting ranges (fills, fonts, borders, number formats)"},{query:"*",include:["index","examples","notes"],search:"tables|sparklines|charts|images|render|validation|conditional|freeze|data_validation",maxChars:2e3,summary:"Grep for feature namespaces"},{query:"fx.*",include:["index","examples","notes"],search:"LET|LAMBDA|XLOOKUP|MAP|BYROW",maxChars:2e3,summary:"Browse formula metadata entries"}]},{kind:"api",name:"workbook.resolve",summary: